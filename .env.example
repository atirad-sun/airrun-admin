# Copy to .env.local and fill in.
# Get these from Supabase Dashboard → Settings → API.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon public key — safe in admin bundle, JWT is the gate>

# Google Maps JavaScript API key — powers the Add Park location
# picker on /parks.  The same key the LIFF app uses is fine, or
# provision a separate one restricted to the admin Vercel domain
# (admin.airrunth.com + localhost:5173).  Without this set, the
# map area in the Add Park dialog renders blank — the form still
# works if you skip the map and enter coords manually below it.
VITE_GOOGLE_MAPS_API_KEY=<google maps js api key>
